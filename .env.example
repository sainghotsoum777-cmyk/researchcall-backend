# ─────────────────────────────────────────────────────────
# ResearchCall API — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ─────────────────────────────────────────────────────────

# ─── Base de données PostgreSQL ───────────────────────────
# Format : postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/researchcall?schema=public"

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET="CHANGEZ-MOI-en-production-clé-secrète-longue-et-aléatoire"
JWT_REFRESH_SECRET="CHANGEZ-MOI-aussi-clé-refresh-différente"

# ─── Serveur ──────────────────────────────────────────────
PORT=3000
NODE_ENV=development
CORS_ORIGIN="*"

# ─── Stockage fichiers (Phase 4) ─────────────────────────
# SUPABASE_URL="https://xxxxx.supabase.co"
# SUPABASE_ANON_KEY="votre-clé-anon"
# SUPABASE_BUCKET="researchcall-files"

# ─── Firebase Cloud Messaging (Phase 5) ──────────────────
# FCM_SERVER_KEY="votre-clé-serveur-fcm"

# ─── Email (Phase 5) ─────────────────────────────────────
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=587
# SMTP_USER="noreply@researchcall.app"
# SMTP_PASS="votre-mot-de-passe-app"
