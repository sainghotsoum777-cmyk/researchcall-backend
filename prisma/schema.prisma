// ─────────────────────────────────────────────────────────
// backend/src/prisma/schema.prisma — Schéma de base de données
// ResearchCall MVP — Phase 1
//
// Modèles : User, Call, Attachment, Favorite, Notification
// Base : PostgreSQL
// ─────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════
// USER — Utilisateur (Chercheur / Publicateur / Admin)
// ═══════════════════════════════════════════════════════════

enum UserRole {
  seeker
  publisher
  both
  admin
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  role         UserRole @default(both)
  institution  String?
  laboratory   String?
  domains      String[] @default([])
  interests    String[] @default([])
  avatarUrl    String?  @map("avatar_url")
  pushToken    String?  @map("push_token")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  publishedCalls Call[]            @relation("PublishedCalls")
  favorites      Favorite[]
  notifications  Notification[]
  refreshTokens  RefreshToken[]

  @@map("users")
}

// ═══════════════════════════════════════════════════════════
// REFRESH TOKEN — Tokens de rafraîchissement
// ═══════════════════════════════════════════════════════════

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ═══════════════════════════════════════════════════════════
// CALL — Appel (Communication, Publication, Colloque…)
// ═══════════════════════════════════════════════════════════

enum CallType {
  communication
  publication
  colloque
  projet
  bourse
  autre
}

enum CallStatus {
  draft
  pending
  published
  expired
  rejected
}

enum LocationModality {
  presentiel
  en_ligne
  hybride
}

model Call {
  id          String   @id @default(uuid())
  publisherId String   @map("publisher_id")
  title       String
  type        CallType
  description String   @db.Text
  status      CallStatus @default(pending)

  // Taxonomie
  thematicAxes String[] @default([]) @map("thematic_axes")
  domains      String[] @default([])
  language     String   @default("fr")

  // Dates
  submissionDeadline DateTime  @map("submission_deadline")
  notificationDate   DateTime? @map("notification_date")
  eventStartDate     DateTime? @map("event_start_date")
  eventEndDate       DateTime? @map("event_end_date")

  // Lieu
  locationCity     String?          @map("location_city")
  locationCountry  String?          @map("location_country")
  locationModality LocationModality @default(presentiel) @map("location_modality")

  // Conditions & contact
  submissionConditions String? @map("submission_conditions") @db.Text
  contactEmail         String  @map("contact_email")
  externalUrl          String? @map("external_url")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  publisher   User         @relation("PublishedCalls", fields: [publisherId], references: [id], onDelete: Cascade)
  attachments Attachment[]
  favorites   Favorite[]

  // Index pour la recherche et le tri
  @@index([publisherId])
  @@index([status])
  @@index([type])
  @@index([submissionDeadline])
  @@index([createdAt])
  @@index([domains])
  @@map("calls")
}

// ═══════════════════════════════════════════════════════════
// ATTACHMENT — Pièce jointe
// ═══════════════════════════════════════════════════════════

model Attachment {
  id       String @id @default(uuid())
  callId   String @map("call_id")
  fileName String @map("file_name")
  fileUrl  String @map("file_url")
  fileSize Int    @map("file_size")   // En octets
  mimeType String @map("mime_type")

  createdAt DateTime @default(now()) @map("created_at")

  call Call @relation(fields: [callId], references: [id], onDelete: Cascade)

  @@index([callId])
  @@map("attachments")
}

// ═══════════════════════════════════════════════════════════
// FAVORITE — Appels sauvegardés
// ═══════════════════════════════════════════════════════════

model Favorite {
  id     String @id @default(uuid())
  userId String @map("user_id")
  callId String @map("call_id")

  savedAt DateTime @default(now()) @map("saved_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  call Call @relation(fields: [callId], references: [id], onDelete: Cascade)

  @@unique([userId, callId])
  @@index([userId])
  @@index([callId])
  @@map("favorites")
}

// ═══════════════════════════════════════════════════════════
// NOTIFICATION — Notifications utilisateur
// ═══════════════════════════════════════════════════════════

enum NotificationType {
  new_call
  deadline_reminder
  moderation_result
}

model Notification {
  id     String           @id @default(uuid())
  userId String           @map("user_id")
  callId String?          @map("call_id")
  title  String
  body   String
  type   NotificationType
  isRead Boolean          @default(false) @map("is_read")

  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@map("notifications")
}
